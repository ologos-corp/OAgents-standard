#!/usr/bin/env bash
# Pre-commit hook: runs QA agent on staged files.
# Commit fails if QA verdict is "fail".
# Install: scripts/install-hooks.sh
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
QA_AGENT="$REPO_ROOT/qa-agent/agent.py"
QA_LOG="$REPO_ROOT/ops/qa_log.json"

# Collect staged files (excluding deleted files, binary, and ops/ log files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d | grep -v '^ops/' || true)

if [ -z "$STAGED_FILES" ]; then
    # Only ops/ files staged — skip QA (avoids recursive loop)
    exit 0
fi

# Skip if qa-agent doesn't exist yet (first-time setup)
if [ ! -f "$QA_AGENT" ]; then
    echo "[QA HOOK] qa-agent/agent.py not found — skipping QA gate"
    exit 0
fi

# Build list of absolute paths
FILE_ARGS=""
for f in $STAGED_FILES; do
    FILE_ARGS="$FILE_ARGS $REPO_ROOT/$f"
done

echo "[QA HOOK] Running QA agent on $(echo "$STAGED_FILES" | wc -l) staged file(s)..."

# Run QA agent, capture output and exit code
QA_OUTPUT=$(cd "$REPO_ROOT/qa-agent" && python3 agent.py $FILE_ARGS --no-log 2>/dev/null) || true
QA_EXIT=$?

# Parse verdict from JSON output
VERDICT=$(echo "$QA_OUTPUT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('verdict','unknown'))" 2>/dev/null || echo "unknown")

if [ "$VERDICT" = "fail" ]; then
    echo ""
    echo "[QA HOOK] ❌ QA FAILED — commit blocked"
    echo ""
    echo "$QA_OUTPUT" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for f in d.get('fail_items', []):
    desc = f if isinstance(f, str) else f.get('description', '')
    print(f'  FAIL: {desc}')
for w in d.get('warnings', []):
    desc = w if isinstance(w, str) else w.get('description', '')
    print(f'  WARN: {desc}')
" 2>/dev/null || true
    echo ""
    echo "Fix the issues above and try again."

    # Log the blocked commit to ops/qa_log.json
    python3 -c "
import json
from datetime import datetime, timezone
path = '$QA_LOG'
data = json.loads(open(path).read())
now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
data['entries'].append({
    'id': f'{now}-pre-commit-blocked',
    'timestamp': now,
    'type': 'compliance_check',
    'severity': 'warning',
    'result': 'fail',
    'model_used': 'gpt-4.1-mini',
    'summary': 'Pre-commit hook blocked commit: QA agent returned fail verdict',
    'details': {
        'artifact_type': 'code',
        'rejection_reason': 'QA agent fail verdict on staged files',
        'corrective_action': None
    }
})
open(path, 'w').write(json.dumps(data, indent=2) + '\n')
" 2>/dev/null || true

    exit 1

elif [ "$VERDICT" = "pass" ] || [ "$VERDICT" = "pass_with_warnings" ]; then
    echo "[QA HOOK] ✅ QA $VERDICT"

    if [ "$VERDICT" = "pass_with_warnings" ]; then
        echo "$QA_OUTPUT" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for w in d.get('warnings', []):
    desc = w if isinstance(w, str) else w.get('description', '')
    print(f'  WARN: {desc}')
" 2>/dev/null || true
    fi

    # Log the pass to ops/qa_log.json
    python3 -c "
import json
from datetime import datetime, timezone
path = '$QA_LOG'
data = json.loads(open(path).read())
now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
data['entries'].append({
    'id': f'{now}-pre-commit-pass',
    'timestamp': now,
    'type': 'compliance_check',
    'severity': 'info',
    'result': 'pass',
    'model_used': 'gpt-4.1-mini',
    'summary': 'Pre-commit hook: QA agent passed on staged files',
    'details': {
        'artifact_type': 'code',
        'rejection_reason': None,
        'corrective_action': None
    }
})
open(path, 'w').write(json.dumps(data, indent=2) + '\n')
" 2>/dev/null || true

    exit 0

else
    # QA agent failed to run or returned unknown verdict
    echo "[QA HOOK] ⚠️  QA agent returned unknown verdict: $VERDICT"
    echo "[QA HOOK] Allowing commit but logging as unverified"

    python3 -c "
import json
from datetime import datetime, timezone
path = '$QA_LOG'
data = json.loads(open(path).read())
now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
data['entries'].append({
    'id': f'{now}-pre-commit-unverified',
    'timestamp': now,
    'type': 'compliance_check',
    'severity': 'warning',
    'result': 'warning',
    'model_used': 'unknown',
    'summary': 'Pre-commit hook: QA agent failed to produce verdict, commit allowed but unverified',
    'details': {
        'artifact_type': 'code',
        'rejection_reason': 'QA agent error or timeout',
        'corrective_action': 'Run QA agent manually after commit'
    }
})
open(path, 'w').write(json.dumps(data, indent=2) + '\n')
" 2>/dev/null || true

    exit 0
fi
